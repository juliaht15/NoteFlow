{
  "project": "NoteFlow",
  "stack": ["Expo", "TypeScript", "React Native Paper", "Zustand", "Shopify FlashList", "Zod"],
  "rules": [
    "Always use functional components and hooks.",
    "Store logic must remain in 'store/notesStore.ts'.",
    "For FlashList type errors (ts2322), use 'const List = FlashList as any'.",
    "Ensure all new screens are added to 'app/(tabs)' or as modals in 'app/'.",
    "Use Haptics for success/error feedback."
  ]
}